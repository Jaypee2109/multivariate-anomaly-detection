# ==========================================================================
# time_series_transformer — Environment Variables
# ==========================================================================
# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults in config.py; only override what you
# want to change.  python-dotenv loads .env automatically if installed.
# ==========================================================================

# -- Kaggle API (required for dataset download) ----------------------------
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key

# -- General ---------------------------------------------------------------
# TRAIN_RATIO=0.7
# RANDOM_STATE=42

# -- Rolling Z-score -------------------------------------------------------
# ROLLING_WINDOW=48
# ROLLING_Z_THRESH=1.8

# -- ARIMA -----------------------------------------------------------------
# ARIMA_P=2
# ARIMA_D=1
# ARIMA_Q=2
# ARIMA_Z_THRESH=8.5

# -- Isolation Forest ------------------------------------------------------
# ISO_CONTAMINATION=0.004

# -- LSTM baseline ---------------------------------------------------------
# LSTM_LOOKBACK=72
# LSTM_HIDDEN_SIZE=32
# LSTM_NUM_LAYERS=1
# LSTM_DROPOUT=0.0
# LSTM_EPOCHS=20
# LSTM_BATCH_SIZE=64
# LSTM_LR=0.001
# LSTM_ERROR_QUANTILE=0.997

# -- VAR (multivariate) ---------------------------------------------------
# VAR_MAXLAGS=5
# VAR_IC=aic
# VAR_Z_THRESH=3.0
# VAR_AGGREGATION=max

# -- Multivariate Isolation Forest ----------------------------------------
# MULTI_ISO_CONTAMINATION=0.01

# -- LSTM Autoencoder (multivariate) --------------------------------------
# LSTM_AE_LOOKBACK=30
# LSTM_AE_HIDDEN_SIZE=64
# LSTM_AE_LATENT_DIM=32
# LSTM_AE_NUM_LAYERS=1
# LSTM_AE_DROPOUT=0.0
# LSTM_AE_EPOCHS=30
# LSTM_AE_BATCH_SIZE=64
# LSTM_AE_LR=0.001
# LSTM_AE_ERROR_QUANTILE=0.99
# LSTM_AE_SCORE_METRIC=mse

# -- LSTM Forecaster (multivariate) ----------------------------------------
# LSTM_FC_LOOKBACK=30
# LSTM_FC_HIDDEN_SIZE=64
# LSTM_FC_NUM_LAYERS=1
# LSTM_FC_DROPOUT=0.0
# LSTM_FC_EPOCHS=30
# LSTM_FC_BATCH_SIZE=64
# LSTM_FC_LR=0.001
# LSTM_FC_ERROR_QUANTILE=0.97
# LSTM_FC_SCORE_METRIC=mse

# -- TranAD (multivariate) ------------------------------------------------
# TRANAD_LOOKBACK=30
# TRANAD_N_HEADS=0                       # 0 = auto (n_features)
# TRANAD_DIM_FF=16
# TRANAD_NUM_LAYERS=1
# TRANAD_DROPOUT=0.1
# TRANAD_EPOCHS=15
# TRANAD_BATCH_SIZE=128
# TRANAD_LR=0.0001
# TRANAD_ERROR_QUANTILE=0.99
# TRANAD_SCORE_METRIC=mse

# -- Custom Transformer (multivariate) ------------------------------------
# CUSTOM_TF_LOOKBACK=30
# CUSTOM_TF_T2V_DIM=16
# CUSTOM_TF_MODEL_DIM=64
# CUSTOM_TF_NUM_HEADS=4
# CUSTOM_TF_NUM_LAYERS=2
# CUSTOM_TF_DIM_FF=256
# CUSTOM_TF_DROPOUT=0.1
# CUSTOM_TF_EPOCHS=15
# CUSTOM_TF_BATCH_SIZE=64
# CUSTOM_TF_LR=0.001
# CUSTOM_TF_ERROR_QUANTILE=0.99
# CUSTOM_TF_SCORE_METRIC=mse

# -- MLflow ----------------------------------------------------------------
# MLFLOW_EXPERIMENT_NAME=Anomaly_Detection

# -- API / Dashboard -------------------------------------------------------
# API_HOST=127.0.0.1
# API_PORT=8000
# ANOMALY_API_URL=http://localhost:8000    # Dashboard HTTP client target
# ANOMALY_WS_HOST=localhost:8000           # Dashboard WebSocket target (host:port)
# ANOMALY_CHECKPOINT_DIR=artifacts/checkpoints
