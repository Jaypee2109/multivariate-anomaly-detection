# ==========================================================================
# time_series_transformer — Environment Variables
# ==========================================================================
# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults in config.py; only override what you
# want to change.  python-dotenv loads .env automatically if installed.
# ==========================================================================

# -- General ---------------------------------------------------------------
# TRAIN_RATIO=0.7
# RANDOM_STATE=42

# -- Rolling Z-score -------------------------------------------------------
# ROLLING_WINDOW=48
# ROLLING_Z_THRESH=1.8

# -- ARIMA -----------------------------------------------------------------
# ARIMA_P=2
# ARIMA_D=1
# ARIMA_Q=2
# ARIMA_Z_THRESH=8.5

# -- Isolation Forest ------------------------------------------------------
# ISO_CONTAMINATION=0.004

# -- LSTM baseline ---------------------------------------------------------
# LSTM_LOOKBACK=72
# LSTM_HIDDEN_SIZE=32
# LSTM_NUM_LAYERS=1
# LSTM_DROPOUT=0.0
# LSTM_EPOCHS=20
# LSTM_BATCH_SIZE=64
# LSTM_LR=0.001
# LSTM_ERROR_QUANTILE=0.997

# -- MLflow ----------------------------------------------------------------
# MLFLOW_EXPERIMENT_NAME=Anomaly_Detection
